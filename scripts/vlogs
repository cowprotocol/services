#!/usr/bin/env bash
# Query Victoria Logs via Grafana API
# Usage: vlogs <expr> [options]
#
# Options:
#   --from <time>         Start time (default: now-12h)
#   --to <time>           End time (default: now)
#   --max <n>             Max log lines (default: 100)
#   --env <prod|staging>  Environment (default: prod)
#   --fields <f1,f2>      Show only these structured fields (e.g. reason,err)
#   --raw                 Dump raw JSON response
#
# Examples:
#   vlogs "NOT container:controller all:0xabc..."
#   vlogs "NOT container:controller filtered all:0xabc..." --fields reason
#   vlogs "settlement failed" --from now-6h --max 50
#   vlogs "error" --env staging --from now-1h

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$SCRIPT_DIR/.env.claude"

FROM="now-12h"
TO="now"
MAX_LINES=100
ENV="prod"
RAW=false
FIELDS=""

EXPR=""
while [[ $# -gt 0 ]]; do
  case $1 in
    --from)   FROM="$2";      shift 2 ;;
    --to)     TO="$2";        shift 2 ;;
    --max)    MAX_LINES="$2"; shift 2 ;;
    --env)    ENV="$2";       shift 2 ;;
    --fields) FIELDS="$2";    shift 2 ;;
    --raw)    RAW=true;       shift   ;;
    --help|-h)
      sed -n '2,15p' "$0"
      exit 0
      ;;
    *)
      EXPR="${EXPR:+$EXPR }$1"
      shift
      ;;
  esac
done

if [[ -z "$EXPR" ]]; then
  sed -n '2,15p' "$0" >&2
  exit 1
fi

case "$ENV" in
  prod)    DS_UID="vm-auth-prod" ;;
  staging) DS_UID="vm-auth-staging" ;;
  *)       echo "Unknown env: $ENV (use prod or staging)" >&2; exit 1 ;;
esac

PAYLOAD=$(jq -n \
  --arg uid "$DS_UID" \
  --arg expr "$EXPR | sort by (_time) asc" \
  --argjson maxLines "$MAX_LINES" \
  --arg from "$FROM" \
  --arg to "$TO" \
  '{queries: [{refId: "A", datasource: {type: "victoriametrics-logs-datasource", uid: $uid}, expr: $expr, queryType: "instant", maxLines: $maxLines}], from: $from, to: $to}')

RESPONSE=$(curl -s --max-time 60 \
  "${GRAFANA_URL}/api/ds/query?ds_type=victoriametrics-logs-datasource" \
  -H 'content-type: application/json' \
  -H "Authorization: Bearer ${GRAFANA_API_TOKEN}" \
  -d "$PAYLOAD")

if [[ -z "$RESPONSE" ]]; then
  echo "Error: empty response (timeout or connection failure)" >&2
  exit 1
fi

if [[ "$RAW" == "true" ]]; then
  echo "$RESPONSE" | jq .
  exit 0
fi

# Format: [HH:MM:SS] message  [target]  key=value  key=value ...
# Structured fields come from the JSON string in labels.all.
# Long values are truncated at 200 chars to keep lines readable.
echo "$RESPONSE" | jq -r --arg fields "$FIELDS" '
  ((.results.A.frames // [])[0] // {}) |
  (.data.values // [[], [], []]) as [$times, $msgs, $labels] |
  if ($msgs | length) == 0 then
    "(no results)"
  else
    [
      range($msgs | length) |
      . as $i |
      ($labels[$i].all? // "{}" | try fromjson catch {}) as $parsed |
      (
        $parsed.fields? // {} | to_entries |
        map(select(.key != "message")) |
        if $fields != "" then
          ($fields | split(",")) as $wanted |
          map(select(.key as $k | $wanted | index($k) != null))
        else . end |
        map(
          .value |= (tostring | if length > 200 then .[:200] + "…" else . end) |
          "  \(.key)=\(.value)"
        ) |
        join("")
      ) as $extra |
      (
        if ($parsed.target? // "") != "" then "  [\($parsed.target)]" else "" end
      ) as $target |
      "[\($times[$i] / 1000 | strftime("%H:%M:%S"))] \($msgs[$i])\($target)\($extra)"
    ] | .[]
  end
' 2>/dev/null || {
  if echo "$RESPONSE" | jq -e '(.results.A.frames // [])[0].data.values[1] | length == 0' >/dev/null 2>&1; then
    echo "(no results)" >&2
  else
    echo "Unexpected response (use --raw to inspect):" >&2
    echo "$RESPONSE" | jq -r '.results | keys[] as $k | .[$k] | select(.error?) | "\($k): \(.error)"' 2>/dev/null || true
    exit 1
  fi
}
